{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": []
    },
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#29315A",
          "foreground": "#3EC669",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "options": {
            "style": "mixed"
          },
          "template": " \ue5ff {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "#29315A",
          "foreground": "#B4D4FF",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#FFCBA4{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#FFB3C1{{ end }}",
            "{{ if gt .Ahead 0 }}#CDB4FF{{ end }}",
            "{{ if gt .Behind 0 }}#CDB4FF{{ end }}"
          ],
          "style": "diamond",
          "trailing_diamond": "\ue0b0",
          "options": {
            "branch_template": "{{ trunc 25 .Branch }}",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ .UpstreamIcon }}{{ .HEAD }} ",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "background": "#1E2A4A",
          "foreground": "#B9FBC0",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "options": {
            "time_format": "15:04:05"
          },
          "template": " {{ .CurrentDate | date .Format }} \uf017 ",
          "type": "time"
        },
        {
          "background": "#253460",
          "foreground": "#FFD6A5",
          "style": "plain",
          "template": "<#1E2A4A>\ue0b3</> {{ .UserName }}@{{ .HostName }} ",
          "type": "session"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#A0F0C0",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#FFB3C1{{ end }}"
          ],
          "options": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "\u276f ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 4
}
