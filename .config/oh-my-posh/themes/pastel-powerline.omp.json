{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": []
    },
    {
      "alignment": "left",
      "segments": [
        {
          "background": "black",
          "foreground": "green",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "options": {
            "style": "mixed"
          },
          "template": " \ue5ff {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "black",
          "foreground": "lightBlue",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}yellow{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}lightMagenta{{ end }}",
            "{{ if gt .Ahead 0 }}lightMagenta{{ end }}",
            "{{ if gt .Behind 0 }}lightMagenta{{ end }}"
          ],
          "style": "diamond",
          "trailing_diamond": "\ue0b0",
          "options": {
            "branch_template": "{{ trunc 25 .Branch }}",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ .UpstreamIcon }}{{ .HEAD }} ",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "background": "black",
          "foreground": "lightGreen",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "options": {
            "time_format": "15:04:05"
          },
          "template": " {{ .CurrentDate | date .Format }} \uf017 ",
          "type": "time"
        },
        {
          "background": "darkGray",
          "foreground": "lightYellow",
          "style": "plain",
          "template": "<black>\ue0b3</> {{ .UserName }}@{{ .HostName }} ",
          "type": "session"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "green",
          "foreground_templates": [
            "{{ if gt .Code 0 }}red{{ end }}"
          ],
          "options": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "\u276f ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 4
}
