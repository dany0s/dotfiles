{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": []
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "#181825",
          "foreground": "#6ec8c8",
          "template": " \ue5ff {{ .Path }} ",
          "options": {
            "style": "mixed"
          }
        },
        {
          "type": "git",
          "style": "diamond",
          "trailing_diamond": "\ue0b0",
          "background": "#181825",
          "foreground": "#89b4fa",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#7dd5f5{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#b4befe{{ end }}",
            "{{ if gt .Ahead 0 }}#b4befe{{ end }}",
            "{{ if gt .Behind 0 }}#b4befe{{ end }}"
          ],
          "template": " {{ .UpstreamIcon }}{{ .HEAD }} ",
          "options": {
            "branch_template": "{{ trunc 25 .Branch }}",
            "fetch_status": true,
            "fetch_upstream_icon": true
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "status",
          "style": "plain",
          "foreground": "#6ec8c8",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#b4befe{{ end }}"
          ],
          "template": "\u276f ",
          "options": {
            "always_enabled": true
          }
        }
      ]
    }
  ],
  "version": 4
}
